{
  "buildCommand": "npm run build:spa",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.fixmymedicalbill.com"
        }
      ],
      "destination": "https://fixmymedicalbill.com/",
      "permanent": true
    },
    {
      "source": "/:path((?!assets/).*)",
      "has": [
        {
          "type": "host",
          "value": "www.fixmymedicalbill.com"
        }
      ],
      "destination": "https://fixmymedicalbill.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/generate.js": {
      "maxDuration": 90,
      "memory": 1024
    }
  }
}
