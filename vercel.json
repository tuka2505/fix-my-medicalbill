{
  "buildCommand": "npm run build:spa",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.fixmymedicalbill.com"
        }
      ],
      "destination": "https://fixmymedicalbill.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/ads\\.txt",
      "dest": "/ads.txt"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/browserconfig\\.xml",
      "dest": "/browserconfig.xml"
    },
    {
      "src": "/security-test\\.html",
      "dest": "/security-test.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/generate.js": {
      "maxDuration": 90,
      "memory": 1024
    }
  }
}
